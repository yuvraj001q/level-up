# ============================================
# LEVEL UP - Environment Variables
# ============================================
# Copy this file to .env and update the values below.

# Database (PostgreSQL) - Get a free one at neon.tech or supabase.com
DATABASE_URL="postgresql://user:password@localhost:5432/level-up"

# NextAuth - Generate a random secret (min 32 chars):
#   Run: openssl rand -base64 32
#   Or visit: https://generate-secret.vercel.app/32
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# NextAuth URL (set to your production domain on Vercel)
AUTH_URL="http://localhost:3000"

# Cron job secret (set this same value in Vercel env vars)
CRON_SECRET="generate-a-random-secret-at-least-32-chars"
