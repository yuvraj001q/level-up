generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
  EPIC
  LEGENDARY
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

enum QuestType {
  DAILY
  WEEKLY
  MONTHLY
}

enum League {
  IRON
  BRONZE
  SILVER
  GOLD
  PLATINUM
  EMERALD
  DIAMOND
  MASTER
  GRANDMASTER
  CHALLENGER
}

enum Goal {
  FITNESS
  LEARNING
  CODING
  READING
  BUSINESS
  SELF_IMPROVEMENT
  NDA_PREPARATION
  CAREER_GROWTH
  COMMUNICATION_SKILLS
  CREATIVITY
  MINDFULNESS
  PRODUCTIVITY
  FINANCE
  HEALTH_WELLNESS
  TRAVEL
  SOCIAL_SKILLS
  WRITING
  LANGUAGE
  MUSIC
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?
  image         String?
  age           Int?
  bio           String?
  goals         Goal[]
  interests     String[]
  productivityLevel Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  level         Int      @default(1)
  xp            Int      @default(0)
  rank          String   @default("Newcomer")
  league        League   @default(BRONZE)
  lastPromotion DateTime?
  achievementPoints Int  @default(0)

  dailyStreak   Int      @default(0)
  weeklyStreak  Int      @default(0)
  longestStreak Int      @default(0)
  lastActiveAt  DateTime?
  streakFreeze  Int      @default(0)

  accounts Account[]
  sessions Session[]

  tasks        Task[]
  quests       Quest[]
  achievements UserAchievement[]
  xpLogs       XpLog[]

  dailyQuestsGeneratedAt DateTime?
  weeklyQuestsGeneratedAt DateTime?
  monthlyQuestsGeneratedAt DateTime?

  emailVerified DateTime?
  phone         String?  @unique
  phoneVerified Boolean  @default(false)
}

model OtpToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  type       String   @default("PHONE")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  used       Boolean  @default(false)

  @@index([identifier, token])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?
  difficulty  TaskDifficulty @default(MEDIUM)
  status      TaskStatus     @default(PENDING)
  category    String?
  deadline    DateTime?
  notes       String?
  isAiGenerated Boolean     @default(false)
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
}

model Quest {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  type        QuestType  @default(DAILY)
  difficulty  TaskDifficulty @default(MEDIUM)
  xpReward    Int        @default(25)
  status      TaskStatus @default(PENDING)
  category    String?
  isBonus     Boolean    @default(false)
  isStreakQuest Boolean  @default(false)
  completedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
}

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String
  description String
  icon        String
  xpReward    Int      @default(50)
  pointsReward Int     @default(10)
  criteria    Json
  createdAt   DateTime @default(now())

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  source    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
